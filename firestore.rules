rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Yardımcı Fonksiyonlar
    function isAuthenticated() {
      return request.auth != null;
    }

    // Kullanıcının tenantId'sini Firestore'dan güvenli şekilde oku
    // Eğer kullanıcı dokümanı yoksa, auth.uid'yi (admin/owner varsayımı) kullan
    function getUserTenantId() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId 
        : request.auth.uid;
    }

    function isTenantMatch(docTenantId) {
      return isAuthenticated() && getUserTenantId() == docTenantId;
    }

    // 1. Poliçeler (Policies) Koleksiyonu Kuralları
    // G-07: Cross-tenant read koruması güçlendirildi
    match /policies/{policyId} {
      // SADECE okuma izni - Yazma işlemleri server-side API üzerinden yapılmalı
      allow read: if isTenantMatch(resource.data.tenantId);

      // Client-side write operations kapatıldı (güvenlik için)
      // Tüm yazma işlemleri /api/policies endpoint'i üzerinden yapılmalı
      allow write: if false;
    }

    // 2. Yapay Zeka Sonuçları (Insights) Koleksiyonu Kuralları
    // Sadece okuma - AI analiz sonuçları yalnızca server-side yazılabilir
    match /insights/{insightId} {
      allow read: if isTenantMatch(resource.data.tenantId);

      // Client-side write koruması - AI insights sadece server tarafından yazılmalı
      allow write: if false;
    }

    // 3. Kullanıcılar (Users) Koleksiyonu Kuralları
    match /users/{userId} {
      // Herkes kendi kullanıcı dökümanına tam erişime sahiptir
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
      // Veya aynı tenant altındaki diğer kullanıcıları okuyabilir (Admin paneli listelemesi için)
      // NOT: isTenantMatch çağrısı, kullanıcı dokümanı yoksa sonsuz döngüye girebilir
      // Bu yüzden resource.data kontrolü yapıyoruz (eğer döküman yoksa zaten izin verilmez)
      allow read: if isAuthenticated() && resource.data != null && isTenantMatch(resource.data.tenantId);
      allow create: if isAuthenticated()
                    && request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && isTenantMatch(request.resource.data.tenantId);
    }

    // 4. Çalışanlar (Employees) Koleksiyonu Kuralları
    match /employees/{employeeId} {
      allow read: if isTenantMatch(resource.data.tenantId);
      allow create: if request.resource.data.tenantId is string
                    && request.resource.data.tenantId.size() > 0
                    && isTenantMatch(request.resource.data.tenantId);
      allow update: if isTenantMatch(resource.data.tenantId)
                    && request.resource.data.tenantId == resource.data.tenantId;
      allow delete: if isTenantMatch(resource.data.tenantId);
    }

    // 5. AI Metrikleri (AI Metrics) Koleksiyonu Kuralları
    // Client-side'dan sadece yazma (log kaydetme) izni var
    // Okuma işlemleri sadece server-side Admin API üzerinden yapılır
    match /aiMetrics/{metricId} {
      // Sadece authenticate edilmiş kullanıcılar metric yazabilir
      // Her metric kendi tenantId'si ile etiketlenir
      allow create: if isAuthenticated()
                    && request.resource.data.tenantId is string
                    && request.resource.data.operation is string
                    && request.resource.data.provider is string;

      // Okuma işlemleri client-side'dan yapılamaz (Admin API üzerinden yapılır)
      allow read, update, delete: if false;
    }

    // 6. Admin Yönetim Koleksiyonu (Tenants)
    match /tenants/{tenantId} {
      // Client-side'dan erişime kapatıldı. Bu koleksiyon sadece Server-side (Admin SDK) ile yönetilmelidir.
      allow read, write: if false;
    }

    // 7. Audit Logs (server-only)
    match /auditLogs/{logId} {
      allow read, write: if false;
    }

    // 8. Varsayılan Güvenlik Duvarı (Fail-Closed)
    // Yukarıda tanımlanmayan hiçbir koleksiyona erişim izni verme
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
